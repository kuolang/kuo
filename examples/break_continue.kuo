// break_continue.kuo - Demonstrate break and continue in loops

print("--- While loop with break/continue ---");
let i: int = 0;
while (i < 10) {
    i = i + 1;

    // skip even numbers
    if ((i % 2) == 0) {
        continue;
    }

    // stop after reaching 7
    if (i > 7) {
        break;
    }

    print(i);
}

print("--- For loop with break ---");
let sum: int = 0;
for (i = 0; i < 100; i++) {
    sum = sum + i;
    if (sum > 50) {
        break;
    }
}
print(sum);

